# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# Virtual environments
.venv/
venv/

# Jupyter
.ipynb_checkpoints/

# Data (large files)
data/raw/*
data/raw/fire/*.h5
!data/raw/fire/
!data/raw/fire/.gitkeep
data/downloads/
*.tif
*.tiff
*.hdf5
*.nc
*.zarr/

# Exception: the BAER Soil Burn Severity raster is the ground truth behind
# notebook 02's only accuracy claim (kappa 0.527). At 198 KB it is small enough
# to bundle, and without it that validation cannot be reproduced from a clone.
# See data/reference/baer/README.md for coding and provenance.
!data/reference/baer/*.tif

# Exception: the AVIRIS-3 granule URL list (~3 KB) lets scripts/download_aviris3.sh
# fetch the ~24 GB validation cubes, which themselves stay out of git.
!data/raw/aviris3/
data/raw/aviris3/*
!data/raw/aviris3/aviris3_jan23_palisades_urls.txt

# Exception: the derived AVIRIS-3 MESMA fraction cube (24 MB) is committed so the
# cross-sensor validation reproduces without the full 24 GB raw download.
!outputs/aviris3_validation/tanager_palisades_fractions.nc

# IDE
.vscode/
.idea/

# OS
.DS_Store

# Development worktrees
.claude/worktrees/

# Secrets
.env
*.key

# Manually-staged research PDFs (license varies — opt in by removing this rule)
research/pdfs/*.pdf

# The Globe-LFMC 2.0 compilation (~220 MB of .xlsx + .csv) stays out of git. It is
# published under CC BY 4.0 at https://doi.org/10.6084/m9.figshare.c.6980418, and
# notebook 03 prints download-and-place instructions when it is absent. Bundling it
# would more than triple the size of a clone for data every user can fetch directly.
data/reference/globe_lfmc/
